{
  "name": "elysia-start-template",
  "version": "0.1.0",
  "module": "src/index.js",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "test": "NODE_ENV=test vitest",
    "test:coverage": "NODE_ENV=test vitest --coverage",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "drizzle:push": "bunx drizzle-kit push --config=src/config/drizzle.config.ts",
    "drizzle:generate": "bunx drizzle-kit generate --config=src/config/drizzle.config.ts",
    "drizzle:migrations": "bunx drizzle-kit migrate --config=src/config/drizzle.config.ts",
    "drizzle:reset": "bun src/db/reset.ts",
    "better-auth:generate": "bunx auth@latest generate --output src/db/schema/auth.ts"
  },
  "dependencies": {
    "@elysia/cors": "^1.4.2",
    "@elysia/openapi": "^1.4.15",
    "better-auth": "^1.6.11",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-seed": "^0.3.1",
    "drizzle-typebox": "^0.3.3",
    "elysia": "latest",
    "elysia-helmet": "^3.1.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.7",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "pino-pretty": "^13.1.3",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "@sinclair/typebox": "0.32.4"
  }
}
